# ---- ~/.claude: defensive guards ----
# chezmoi only manages files you explicitly `chezmoi add`, but these ensure
# secrets/runtime state can never be swept in accidentally.
# SECRETS — never track:
.claude/.credentials.json
.claude/history.jsonl
# Runtime / regenerated state:
.claude/backups
.claude/cache
.claude/daemon
.claude/daemon.*
.claude/downloads
.claude/file-history
.claude/jobs
.claude/paste-cache
.claude/projects
.claude/session-env
.claude/sessions
.claude/shell-snapshots
.claude/todos
.claude/statsig
.claude/.last-*
.claude/*.lock
.claude/mcp-needs-auth-cache.json
.claude/settings.json.bak-*
.claude/settings.local.json
# Plugins: track the registry (known_marketplaces.json) but not fetched code/caches:
.claude/plugins/cache
.claude/plugins/marketplaces
.claude/plugins/repos
.claude/plugins/installed_plugins.json
.claude/plugins/plugin-catalog-cache.json
.claude/plugins/.last_inuse_sweep

# ---- ~/.ssh: defensive guards (this repo is PUBLIC) ----
# Only ~/.ssh/config is tracked. Private keys must NEVER be committed —
# a leaked private key in a public repo is an instant compromise.
.ssh/id_*
.ssh/*_key
.ssh/*.pem
.ssh/known_hosts*
