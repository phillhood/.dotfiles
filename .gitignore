# Claude Code's own project config for THIS repo (not part of the dotfiles) — never track.
# Anchored (leading /) so it hits ONLY the repo root, not the claude/.claude/ stow package.
/.claude/

# superpowers SDD scratch
.superpowers/

# ---- Public-repo secret guards (defense-in-depth) ----
# The Makefile uses `stow --no-folding`, so ~/.ssh and ~/.claude are never folded
# into repo-pointing dir symlinks — secrets should never reach the repo tree. These
# scoped ignores are a backstop so a stray key/credential can never be committed.
# ssh package: private keys and host state must NEVER be committed
ssh/.ssh/id_*
ssh/.ssh/*_key
ssh/.ssh/*.pem
ssh/.ssh/known_hosts*
# claude package: credentials and per-user/runtime state
claude/.claude/.credentials.json
claude/.claude/history.jsonl
claude/.claude/settings.local.json
# settings.json is plugin-managed (GSD rewrites hooks) → untracked; canonical copy in tools/canonical/
claude/.claude/settings.json
# plugin registry + marketplaces are runtime state Claude rewrites (breaks the symlink)
claude/.claude/plugins/

# ---- Desktop packages: build/backup/state, never track ----
# hypr bundles a git-clone of split-monitor-workspaces (rebuilt by hyprpm)
hypr/.config/hypr/plugins/
# waybar keeps old config snapshots
waybar/.config/waybar/backup/
# editor/backup copies anywhere
*.bak
