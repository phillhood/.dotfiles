#!/usr/bin/env python3
"""herdr-agents - waybar element for Claude Code / herdr agent status.

One waybar module per status (blocked/idle/done/working/unknown), grouped into
one card. Each status module shows its icon + count, hides when empty, tooltips
the agents in that status, and focuses one of them on click.

Subcommands:
  status <name>        emit one status module's JSON (icon + count) and exit
  focus-status <name>  focus a herdr agent in <name> status (+ raise the window)
  notify               watch herdr and nudge waybar (RTMIN+SIGNAL) whenever the
                       set of agents/statuses changes, so the status modules
                       re-render

Self-contained: all personal choices live in the CONFIG block below, so this
script can later move to a standalone repo unchanged.
"""
import json
import os
import shutil
import subprocess
import sys
import time

# ----------------------------- CONFIG -----------------------------
# Known statuses, in the left-to-right order the status modules appear.
URGENCY = ["blocked", "idle", "done", "working", "unknown"]

# Nerd-font glyphs (MesloLGS Nerd Font), by codepoint to avoid paste rot.
ICONS = {
    "blocked": "\U000F009A",  # md-bell
    "idle":    "\U000F0134",  # md-check-bold
    "done":    "\U000F05E0",  # md-check-circle
    "working": "\U000F06A9",  # md-robot
    "unknown": "\U000F02D7",  # md-help-circle
}

# Catppuccin Macchiato.
COLORS = {
    "blocked": "#ed8796",  # red
    "idle":    "#a6da95",  # green
    "done":    "#8bd5ca",  # teal
    "working": "#c6a0f6",  # mauve
    "unknown": "#6e738d",  # overlay0
}

# waybar signal (SIGRTMIN+SIGNAL) the `notify` watcher raises when the agent
# state changes; the status modules carry the matching "signal" and re-render.
SIGNAL = 8

# How often `notify` re-checks herdr. herdr's agent-status events are per-pane
# (no global "any agent changed" subscription), so a light poll of the cheap
# local-socket `agent list` is the robust way to catch every change. A nudge is
# sent only when the state actually differs, so waybar re-renders on real
# changes, not on a timer.
POLL_SECONDS = 1.5

HERDR_BIN = (os.environ.get("HERDR_BIN")
             or shutil.which("herdr")
             or os.path.expanduser("~/.local/bin/herdr"))

GHOSTTY_CLASS = "com.mitchellh.ghostty"
HERDR_WINDOW_TITLE = "herdr"
# ------------------------------------------------------------------


def status_of(agent):
    s = agent.get("agent_status") or "unknown"
    return s if s in URGENCY else "unknown"


def stable_sort(agents):
    # Stable, workspace-grouped order (pane_id is "w5:p1") so a status's
    # first agent - and the tooltip order - don't jump around on status change.
    return sorted(agents, key=lambda a: a.get("pane_id", ""))


def pango_escape(text):
    return (text.replace("&", "&amp;")
                .replace("<", "&lt;")
                .replace(">", "&gt;"))


def agent_line(agent):
    ws = agent.get("workspace_id", "?")
    title = (agent.get("terminal_title_stripped") or "").strip()
    return "%s  %s" % (pango_escape(ws), pango_escape(title))


def status_output(name, agents):
    matching = [a for a in agents if status_of(a) == name]
    if not matching:
        return {"text": "", "tooltip": "", "class": ["herdr-agents", name, "empty"]}
    text = "<span color='%s'>%s</span> %d" % (COLORS[name], ICONS[name], len(matching))
    tooltip = "\n".join(agent_line(a) for a in stable_sort(matching))
    return {"text": text, "tooltip": tooltip, "class": ["herdr-agents", name]}


def state_signature(agents):
    # A hashable summary of what the row shows; changes exactly when a status
    # count or an agent's status changes (order-independent).
    return tuple(sorted((a.get("pane_id", ""), status_of(a)) for a in agents))


def emit(out):
    sys.stdout.write(json.dumps(out) + "\n")
    sys.stdout.flush()


def fetch_agents():
    try:
        p = subprocess.run([HERDR_BIN, "agent", "list"],
                           capture_output=True, text=True, timeout=3)
        data = json.loads(p.stdout)
        return data.get("result", {}).get("agents", []) or []
    except Exception:
        return []


def pick_herdr_window(clients):
    for c in clients:
        if c.get("title") == HERDR_WINDOW_TITLE:
            return c
    for c in clients:
        if c.get("class") == GHOSTTY_CLASS:
            return c
    return None


def raise_herdr_window():
    try:
        p = subprocess.run(["hyprctl", "-j", "clients"],
                           capture_output=True, text=True, timeout=3)
        clients = json.loads(p.stdout)
        win = pick_herdr_window(clients)
        if win and win.get("address"):
            # This box runs Hyprland's Lua-config plugin, which evaluates
            # `hyprctl dispatch <x>` as `hl.dispatch(<x>)`; hl.dsp.focus with a
            # window selector is the focuswindow equivalent. (Stock hyprlang
            # Hyprland would instead use: dispatch focuswindow address:<addr>.)
            subprocess.run(
                ["hyprctl", "dispatch",
                 'hl.dsp.focus({window="address:%s"})' % win["address"]],
                capture_output=True, text=True)
    except Exception:
        pass


def focus_agent(terminal_id):
    if not terminal_id:
        return
    try:
        subprocess.run([HERDR_BIN, "agent", "focus", terminal_id],
                       capture_output=True, text=True)
    except Exception:
        pass
    raise_herdr_window()


def nudge():
    try:
        subprocess.run(["pkill", "-RTMIN+%d" % SIGNAL, "waybar"],
                       capture_output=True)
    except Exception:
        pass


def cmd_status(name):
    emit(status_output(name, fetch_agents()))


def cmd_focus_status(name):
    matching = stable_sort([a for a in fetch_agents() if status_of(a) == name])
    if matching:
        focus_agent(matching[0].get("terminal_id"))


def cmd_notify():
    emit({"text": "", "class": ["herdr-agents", "notify"]})  # stay hidden
    last = None
    while True:
        try:
            sig = state_signature(fetch_agents())
            if sig != last:
                last = sig
                nudge()
        except Exception as exc:
            sys.stderr.write("herdr-agents notify: %s\n" % exc)
        time.sleep(POLL_SECONDS)


def main(argv):
    cmd = argv[1] if len(argv) > 1 else "notify"
    if cmd == "status" and len(argv) > 2:
        cmd_status(argv[2])
        return 0
    if cmd == "focus-status" and len(argv) > 2:
        cmd_focus_status(argv[2])
        return 0
    if cmd == "notify":
        cmd_notify()
        return 0
    sys.stderr.write(
        "usage: herdr-agents {status <name>|focus-status <name>|notify}\n")
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv))
