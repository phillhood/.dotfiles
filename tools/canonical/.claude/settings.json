{
  "permissions": {
    "allow": [
      "Read(.planning/*)",
      "Write(.planning/*)",
      "Read(STATE.md)",
      "Write(STATE.md)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.secrets)"
    ],
    "defaultMode": "default"
  },
  "model": "opus",
  "effortLevel": "xhigh",
  "advisorModel": "fable",
  "theme": "dark",
  "statusLine": {
    "type": "command",
    "command": "/home/phill/.claude/ccline/ccline",
    "padding": 0
  },
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/uv-python.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": false
}
