# Default settings
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[merge]
	conflictstyle = zdiff3
[core]
	excludesfile = ~/.gitignore_global
	sshCommand = ssh -i ~/.ssh/id_phill -o IdentitiesOnly=yes
	editor = code --wait

# Personal identity (default)
[user]
	email = phill@phillhood.ca
	name = Phill Hood

# Hobby identity 
[includeIf "gitdir:~/Dev/shychedelic/"]
	path = ~/.gitconfig-shy
